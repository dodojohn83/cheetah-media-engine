{
  "name": "cheetah-ffmpeg-wasm",
  "version": "0.1.0",
  "ffmpeg": {
    "version": "8.1.2",
    "source": "https://git.ffmpeg.org/gitweb/ffmpeg.git/snapshot/n8.1.2.tar.gz",
    "configure_flags": [
      "--disable-gpl",
      "--disable-nonfree",
      "--enable-shared",
      "--disable-programs",
      "--disable-doc",
      "--disable-avdevice",
      "--disable-postproc",
      "--disable-avfilter",
      "--disable-encoders",
      "--disable-muxers",
      "--enable-decoder=h264",
      "--enable-decoder=hevc",
      "--enable-decoder=aac",
      "--enable-decoder=mp3",
      "--enable-demuxer=flv",
      "--enable-demuxer=hls",
      "--enable-demuxer=mov,mp4,m4a,3gp,3g2,mj2",
      "--enable-swresample",
      "--enable-avutil"
    ]
  },
  "emscripten": {
    "version": "6.0.2"
  },
  "license": "LGPL-2.1-or-later",
  "output": {
    "wasm": "cheetah_ffmpeg.wasm",
    "js": "cheetah_ffmpeg.js"
  }
}

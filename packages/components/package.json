{
  "name": "@cheetah-media/components",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Cheetah Media Engine Web Components (custom elements) for player and multiview wall.",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dodojohn83/cheetah-media-engine.git",
    "directory": "packages/components"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/cheetah-media-components.iife.js",
  "jsdelivr": "./dist/cheetah-media-components.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/cheetah-media-components.iife.js"
    },
    "./iife": {
      "types": "./dist/index.d.ts",
      "default": "./dist/cheetah-media-components.iife.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "echo 'lint placeholder'"
  },
  "dependencies": {
    "@cheetah-media/web": "workspace:*"
  },
  "devDependencies": {
    "happy-dom": "15.11.7",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
